{
  "name": "layered-monolith-orders-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint ./src --ext .ts",
    "format": "prettier --write .",
    "test": "jest --passWithNoTests",
    "test:unit": "jest -c jest.config.cjs --selectProjects unit",
    "test:e2e": "jest -c jest.config.cjs --selectProjects e2e",
    "test:ci": "jest --coverage"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.0.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.44.0"
  }
}
